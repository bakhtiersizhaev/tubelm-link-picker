{
  "manifest_version": 3,
  "name": "TubeLM Link Picker",
  "short_name": "TubeLM",
  "version": "1.2",
  "description": "Select YouTube videos and Shorts, copy clean URLs, and paste them into NotebookLM or AI research notes.",
  "homepage_url": "https://github.com/bakhtiersizhaev/tubelm-link-picker",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}
